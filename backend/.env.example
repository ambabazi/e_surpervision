# Copy to backend/.env and adjust values
# cp .env.example .env

# --- Database (PostgreSQL) ---
#
# RECOMMENDED when password contains @, #, or other special characters:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_pgadmin_password_here
PGDATABASE=e_supervision
#
# Alternative: single DATABASE_URL (password MUST be URL-encoded: @ → %40, # → %23)
# DATABASE_URL=postgresql://postgres:Hello12%4012@localhost:5432/e_supervision
#
# Do NOT put an unencoded @ in the password part of DATABASE_URL — it breaks parsing.

# --- Security (change in production!) ---
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters
JWT_EXPIRATION_HOURS=48

# --- CORS (frontend URL) ---
CORS_ORIGINS=http://localhost:5173

# --- Email (Gmail SMTP — progress & proposal notifications to student Gmail) ---
# 1. Enable 2FA on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Set MAIL_ENABLED=true and use smtp.gmail.com
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.sender@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_USE_TLS=true
MAIL_FROM=your.sender@gmail.com
